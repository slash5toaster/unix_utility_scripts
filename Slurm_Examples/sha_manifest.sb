#!/usr/bin/env bash

#SBATCH --job-name=sha_manifest
#SBATCH --output=/scratch/site/u/jonesc47/jobs/shasum_%J.out
#SBATCH --error=/scratch/site/u/jonesc47/jobs/shasum_%J.err
#SBATCH --qos=3h
#SBATCH --cpus-per-task=48
#SBATCH --mem-per-cpu=1G

# Load necessary modules
ml parallel

if [[ -z ${MANIFEST_DIR} ]] ; then
   MANIFEST_DIR=${1:-$(pwd)}
fi

test -d ${MANIFEST_DIR} || ( echo "${MANIFEST_DIR} is not a directory" >&2 ; exit 3)

sha_manifest.sh ${MANIFEST_DIR}
